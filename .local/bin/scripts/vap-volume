#!/bin/sh

# Prints the current volume or рџ”‡ if muted.

case $BUTTON in
	1) pavucontrol ;;
	2) wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle ;;
	4) wpctl set-volume @DEFAULT_AUDIO_SINK@ 1%+ ;;
	5) wpctl set-volume @DEFAULT_AUDIO_SINK@ 1%- ;;
	3) notify-send "рџ“ў Volume module" "\- Shows volume пЂЁ  , о»Ё   if muted.
- Middle click to mute.
- Scroll to change." ;;
esac

vol="$(wpctl get-volume @DEFAULT_AUDIO_SINK@)"

# If muted, print рџ”‡ and exit.
[ "$vol" != "${vol%\[MUTED\]}" ] && echo "^C5^[ о»Ё  ]" && exit

vol="${vol#Volume: }"

split() {
	# For ommiting the . without calling and external program.
	IFS=$2
	set -- $1
	printf '%s' "$@"
}

vol="$(printf "%.0f" "$(split "$vol" ".")")"

case 1 in
	$((vol >= 70)) ) icon="пЂЁ  " ;;
	$((vol >= 30)) ) icon="пЂ§  " ;;
	$((vol >= 1)) ) icon="пЂ¦  " ;;
	* ) echo о»Ё   && exit ;;
esac

echo "^C6^[$icon$vol%]"
