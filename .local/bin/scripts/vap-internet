#!/bin/sh

# Show wifi рџ“¶ and percent strength or рџ“Ў if none.
# Show рџЊђ if connected to ethernet or вќЋ if none.
# Show рџ”’ if a vpn connection is active

case $BUTTON in
	1) st -e nmtui ;;
	3) notify-send "рџЊђ Internet module" "\- Click to connect
пЂЌ  : wifi disabled
оЅ   : no wifi connection
пЂ’   : wifi connection with quality
п‚¬  : no ethernet
оЅ„  : ethernet working
у°–‚  : vpn is active
" ;;
esac

# Ethernet
if [[ "$(cat /sys/class/net/e*/operstate 2>/dev/null)" = "up" ]]; then
    ethericon=" ^B14^^C0^   оЅ„    ^d^^C14^  Connected"

# Wifi
else
    if [ "$(cat /sys/class/net/wlan1/operstate 2>/dev/null)" = 'up' ] ; then
        wifiicon="$(awk '/^\s*w/ { print " ^B14^^C0^  пЂ’    ^d^^C14^  ", int($3 * 100 / 70) "%" }' /proc/net/wireless)"
    elif [ "$(cat /sys/class/net/wlan1/operstate 2>/dev/null)" = 'down' ] ; then
        [ "$(cat /sys/class/net/wlan1/flags 2>/dev/null)" = '0x1003' ] && wifiicon=" ^B14^^C0^  оЅ    ^d^^C14^  Not Connected" || wifiicon="п‘§  "
    fi
fi

# TUN
[ -n "$(cat /sys/class/net/tun*/operstate 2>/dev/null)" ] && tunicon=" ^B14^^C0^    у°–‚    ^d^^C14^  Vpn"

printf "%s%s%s\n" "$wifiicon$ethericon $tunicon"
