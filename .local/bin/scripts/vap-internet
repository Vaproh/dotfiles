#!/bin/sh

# Show wifi ΏθΥ╢ and percent strength or ΏθΥκ if none.
# Show ΏθΝΡ if connected to ethernet or έζΟ if none.
# Show ΏθΦΤ if a vpn connection is active

case $BUTTON in
	1) st -e nmtui ;;
	3) notify-send "ΏθΝΡ Internet module" "\- Click to connect
ΎΑΞ  : wifi disabled
Ό╜ι  : no wifi connection
ΎΑΤ   : wifi connection with quality
≤░ΙΓ  : no ethernet
≤░ΙΒ  : ethernet working
≤░ΨΓ  : vpn is active
" ;;
esac

# Wifi
if [ "$(cat /sys/class/net/w*/operstate 2>/dev/null)" = 'up' ] ; then
	wifiicon="$(awk '/^\s*w/ { print "ΎΑΤ  ", int($3 * 100 / 70) "% " }' /proc/net/wireless)"
elif [ "$(cat /sys/class/net/w*/operstate 2>/dev/null)" = 'down' ] ; then
	[ "$(cat /sys/class/net/w*/flags 2>/dev/null)" = '0x1003' ] && wifiicon="Ό╜ι  " || wifiicon="ΎΣπ  "
fi

# Ethernet
[ "$(cat /sys/class/net/e*/operstate 2>/dev/null)" = 'up' ] && ethericon="≤░ΙΒ" || ethericon="≤░ΙΓ"

# TUN
[ -n "$(cat /sys/class/net/tun*/operstate 2>/dev/null)" ] && tunicon=" ≤░ΨΓ "

printf "^C6^[%s%s%s\n" "$wifiicon$ethericon$tunicon]"
